#![allow(
    dead_code,
    non_camel_case_types,
    non_snake_case,
    non_upper_case_globals,
    unused_assignments,
    unused_mut
)]
extern "C" {
    fn printf(format: *const ::core::ffi::c_char, ...) -> ::core::ffi::c_int;
}
#[no_mangle]
pub unsafe extern "C" fn lift_const(
    mut argc: ::core::ffi::c_int,
    mut argv: *mut *mut ::core::ffi::c_char,
) {
    let mut starts_with_a: ::core::ffi::c_int = 0;
    if !(argc == 3 as ::core::ffi::c_int) {
        starts_with_a = (**argv.offset(0 as ::core::ffi::c_int as isize) as ::core::ffi::c_int
            == 'a' as i32) as ::core::ffi::c_int;
        if starts_with_a != 0 {
            printf(b"  (arg 0 starts with 'a')\n\0".as_ptr() as *const ::core::ffi::c_char);
        }
    }
    if argc == 3 as ::core::ffi::c_int {
        printf(b"  (argc was 3)\n\0".as_ptr() as *const ::core::ffi::c_char);
    }
}
