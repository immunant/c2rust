#[no_mangle]
pub unsafe extern "C" fn side_effect(mut x: *mut std::ffi::c_int) -> std::ffi::c_int {
    *x = 1 as std::ffi::c_int;
    return 10 as std::ffi::c_int;
}
#[no_mangle]
pub unsafe extern "C" fn unary_without_side_effect() {
    let mut i: std::ffi::c_int = 5 as std::ffi::c_int;
    i += 1;
    i -= 1;
    i -= 1;
    i += 1;
}
#[no_mangle]
pub unsafe extern "C" fn unary_with_side_effect(buffer: *mut std::ffi::c_int) {
    let mut arr: [*mut std::ffi::c_char; 1] = [0 as *mut std::ffi::c_char];
    -side_effect(&mut *buffer.offset(1 as std::ffi::c_int as isize));
    side_effect(&mut *buffer.offset(2 as std::ffi::c_int as isize));
    !side_effect(&mut *buffer.offset(3 as std::ffi::c_int as isize));
    (side_effect(&mut *buffer.offset(4 as std::ffi::c_int as isize)) == 0) as std::ffi::c_int;
    &*(b"\0" as *const u8 as *const std::ffi::c_char).offset((side_effect
        as unsafe extern "C" fn(*mut std::ffi::c_int) -> std::ffi::c_int)(
        &mut *buffer.offset(5 as std::ffi::c_int as isize),
    ) as isize) as *const std::ffi::c_char;
    *arr[side_effect(&mut *buffer.offset(6 as std::ffi::c_int as isize)) as usize];
    arr[side_effect(&mut *buffer.offset(7 as std::ffi::c_int as isize)) as usize] =
        (arr[side_effect(&mut *buffer.offset(7 as std::ffi::c_int as isize)) as usize]).offset(1);
    arr[side_effect(&mut *buffer.offset(8 as std::ffi::c_int as isize)) as usize] =
        (arr[side_effect(&mut *buffer.offset(8 as std::ffi::c_int as isize)) as usize]).offset(-1);
    arr[side_effect(&mut *buffer.offset(9 as std::ffi::c_int as isize)) as usize] =
        (arr[side_effect(&mut *buffer.offset(9 as std::ffi::c_int as isize)) as usize]).offset(1);
    arr[side_effect(&mut *buffer.offset(10 as std::ffi::c_int as isize)) as usize] =
        (arr[side_effect(&mut *buffer.offset(10 as std::ffi::c_int as isize)) as usize]).offset(-1);
}
